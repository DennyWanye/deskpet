node_modules/
target/
dist/
__pycache__/
*.pyc
.venv/
*.egg-info/
build/
.DS_Store
Thumbs.db
*.log
crash_reports/
logs/

# Voice pipeline model weights & runtime artifacts (GB-scale, not for git)
# P3-S1: renamed assets/ -> models/; keep old path for local devs mid-migration.
backend/models/
backend/assets/
backend/temp/
temp/

# Portable ffmpeg.exe (~80MB) for MP3->PCM pipe in voice pipeline.
# Provisioned via scripts/setup_ffmpeg.ps1 — not source.
backend/bin/

# E2E driver screenshots — regenerated on every run, not source-of-truth
scripts/e2e/shots/
scripts/e2e/shots_cdp/
scripts/e2e/deskpet_window.png

# P2-2-F1: ASR accuracy bench samples — each tester records their own
# voice so committing them adds no universal signal + bloats the repo.
scripts/perf/asr_samples/

# Tauri signing keys (NEVER commit private keys)
# Private key lives in ~/.tauri/ on maintainer's machine + CI secret.
*.key
*.key.pub
.tauri/

# `gh` CLI dump artifacts that occasionally land at repo root during
# manual debugging (gh run list --json > runs.json etc). Not source.
/jobs.json
/runs.json
/run.json
/release.json
/logs.zip

# Claude Code scheduled-task runtime files / per-agent worktrees.
.claude/scheduled_tasks.lock
.claude/worktrees/
.claude/codex-tasks/
.claude/tauri_dev.log.err
backend/.claude/
/logs/

# P4-S15: dev-only L2 conversation DB. Real path is %AppData%/deskpet/data/.
# Local CWD-relative leftover from old runs.
/data/

# P4-S2: BGE-M3 INT8 weights (~286MB after quantise, 2.2GB fp16 source)
# — downloaded on first run by backend/scripts/download_bge_m3.py, not in git.
backend/models/bge-m3-int8/

# P4-S1: DB migration backups. v8_to_v9 creates state.db.bak and *.db.bak.<ts>
# before any schema ALTER so the restore path in task 2.3 can roll back.
*.db.bak
state.db.bak.*

# P4-S2: async embedding worker cache (intermediate BGE-M3 tensors written
# when the flush queue is draining — regenerable from the source messages).
backend/deskpet/memory/embedding_cache/

# P4-S7: ContextAssembler trace dumps written by decisions debug mode.
# Local-only, generated on demand via the Context Trace UI — not source.
debug/assembler_trace_*.json
