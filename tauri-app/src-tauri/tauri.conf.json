{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "DeskPet",
  "version": "0.6.0-phase4-rc3",
  "identifier": "com.deskpet.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Desktop Pet",
        "width": 400,
        "height": 600,
        "x": 2100,
        "y": 640,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "wix": {
        "// rc2-T1": "MSI/WiX requires X.Y.Z.W 4-segment numeric version. SemVer pre-release (`-phase4-rc3`) is not accepted, so we override here. Encoding: phase4 → minor 6, rc3 → build 3. Bump on every rc.",
        "version": "0.6.0.3"
      }
    },
    "resources": {
      "../../backend/dist/deskpet-backend": "backend"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/DennyWanye/deskpet/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVGNjIzRTVDREJBQTRDNUEKUldSYVRLcmJYRDVpWHlMN1d1bjNwVE5SdGNqQXFLdml5THkvZHV6cTNrOFQwN2hXVk92YkgzaEQK"
    }
  }
}
